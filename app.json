{
  "expo": {
    "name": "P2P Kollections",
    "slug": "p2pkollections",
    "version": "1.0.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "scheme": "p2pkollections",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#011501"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.p2pkollections.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#011501"
      },
      "package": "com.p2pkollections.app"
    },
    "plugins": [
      ["expo-router"],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 29
          }
        }
      ]
    ]
  }
}
